{
  "name": "wrap",
  "type": "module",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "start": "bun run src/index.ts",
    "build:watch": "bun build src/index.ts --compile --outfile wrap --watch",
    "build": "bun build src/index.ts --compile --outfile wrap",
    "test": "bun test",
    "lint": "bunx biome check . --error-on-warnings",
    "format": "bunx biome format . --write",
    "check": "bunx biome check . --error-on-warnings && bun test",
    "optimize": "docker build -t wrap-dspy eval/dspy && docker run --rm -v \"$(pwd)/eval\":/app/eval -v \"$(pwd)/src\":/app/src --env-file eval/dspy/.env wrap-dspy && bunx biome format src/prompt.optimized.ts --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/bun": "latest"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/openai": "^3.0.48",
    "ai": "^6.0.137",
    "jsonc-parser": "^3.3.1",
    "zod": "^4.3.6"
  }
}
