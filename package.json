{
  "name": "wrap",
  "type": "module",
  "private": true,
  "version": "0.0.6-rc.1",
  "license": "MIT",
  "scripts": {
    "start": "bun run src/index.ts",
    "build:watch": "watchexec -w src bun run scripts/build.ts",
    "build": "bun run scripts/build.ts",
    "release": "bun run scripts/release.ts",
    "test": "bun test",
    "mutate": "stryker run stryker/stryker.config.json",
    "lint": "bunx biome check . --write --error-on-warnings && bunx tsc --noEmit",
    "check": "bun run lint && bun test",
    "optimize": "docker build -t wrap-dspy -f eval/dspy/Dockerfile . && docker run --rm -v \"$(pwd)/eval/examples\":/app/eval/examples -v \"$(pwd)/eval/results\":/app/eval/results -v \"$(pwd)/eval/dspy\":/app/eval/dspy -v \"$(pwd)/eval/bridge.ts\":/app/eval/bridge.ts -v \"$(pwd)/src\":/app/src --env-file eval/dspy/.env wrap-dspy && bunx biome format src/prompt.optimized.json --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@stryker-mutator/core": "^9.6.1",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "typescript": "5"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/openai": "^3.0.53",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@inkjs/ui": "^2.0.0",
    "ai": "^6.0.168",
    "ink": "^7.0.1",
    "jsonc-parser": "^3.3.1",
    "react": "^19.2.5",
    "string-width": "^8.2.0",
    "zod": "^4.3.6"
  }
}
