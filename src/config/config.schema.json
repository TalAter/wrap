{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Wrap configuration file",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "maxRounds": {
      "type": "integer",
      "description": "Maximum number of LLM rounds (probes + error-fix attempts) per invocation. Default: 5.",
      "minimum": 1,
      "default": 5
    },
    "maxProbeOutputChars": {
      "type": "integer",
      "description": "Maximum characters of probe command output sent to the LLM. Longer output is truncated. Default: 200000 (~200KB).",
      "minimum": 1000,
      "default": 200000
    },
    "verbose": {
      "type": "boolean",
      "description": "Enable verbose mode. Surfaces internal pipeline steps on stderr.",
      "default": false
    },
    "provider": {
      "description": "LLM provider configuration",
      "oneOf": [
        {
          "type": "object",
          "description": "Anthropic API provider via AI SDK",
          "properties": {
            "type": { "const": "anthropic" },
            "model": {
              "type": "string",
              "description": "Model to use (default: claude-sonnet-4-latest)"
            },
            "apiKey": {
              "type": "string",
              "description": "API key. Use \"$ENV_VAR\" to read from environment. Omit to use ANTHROPIC_API_KEY."
            },
            "baseURL": {
              "type": "string",
              "description": "Custom API endpoint (for proxies, etc.)"
            }
          },
          "required": ["type"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "description": "OpenAI API provider via AI SDK",
          "properties": {
            "type": { "const": "openai" },
            "model": {
              "type": "string",
              "description": "Model to use (default: gpt-4o-mini)"
            },
            "apiKey": {
              "type": "string",
              "description": "API key. Use \"$ENV_VAR\" to read from environment. Omit to use OPENAI_API_KEY."
            },
            "baseURL": {
              "type": "string",
              "description": "Custom API endpoint (for Ollama, proxies, etc.)"
            }
          },
          "required": ["type"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "description": "Claude Code CLI provider",
          "properties": {
            "type": { "const": "claude-code" },
            "model": {
              "type": "string",
              "description": "Model to use (e.g. sonnet, haiku, opus)"
            }
          },
          "required": ["type"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "description": "Test provider — echoes input back (for development/testing)",
          "properties": {
            "type": { "const": "test" }
          },
          "required": ["type"],
          "additionalProperties": false
        }
      ]
    }
  },
  "additionalProperties": false
}
